# MCP-Strike — example environment file.
#
# Copy this to `.env` and fill in real values. `.env` is gitignored.
# Secrets must NEVER be hardcoded in source.
#
# The CLI auto-loads `.env` from the current working directory at startup
# (see src/mcp_strike/config/dotenv.py). Shell-exported variables still
# take precedence — `export OPENAI_API_KEY=...` in your shell will override
# whatever this file says.

# --- LLM judge (Phase 2) -----------------------------------------------------
# Required when the judge is enabled. The CLI's --judge flag auto-detects:
# judge runs iff OPENAI_API_KEY is set (override with --judge / --no-judge).

# OPENAI_API_KEY=sk-...

# Optional: override the default judge model (currently gpt-4o-mini).
# MCP_STRIKE_JUDGE_MODEL=gpt-4o-mini
