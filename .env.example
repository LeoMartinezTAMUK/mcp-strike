# MCP-Strike — example environment file.
#
# Copy this to `.env` and fill in real values. `.env` is gitignored.
# Secrets must NEVER be hardcoded in source.
#
# Nothing in Phase 0 actually reads these yet; they're declared here so the
# shape is in place when the judge and agent land in later phases.

# --- LLM judge / adaptive agent (used in Phase 2+) ---------------------------
# Pick whichever provider you'll use; you don't need both.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Default judge model. Keep it cheap — judge calls run on every attack.
# MCP_STRIKE_JUDGE_MODEL=claude-haiku-4-5

# Per-run cap on LLM judge/agent calls. Hard ceiling to prevent surprise bills.
# MCP_STRIKE_MAX_LLM_CALLS=100
