# MCP-Strike — example environment file.
#
# Copy this to `.env` and fill in real values. `.env` is gitignored.
# Secrets must NEVER be hardcoded in source.
#
# The CLI auto-loads `.env` from the current working directory at startup
# (see src/mcp_strike/config/dotenv.py). Shell-exported variables still
# take precedence — `export OPENAI_API_KEY=...` in your shell will override
# whatever this file says.

# --- LLM judge + adaptive agent (Phase 2 + Phase 3) --------------------------
# OPENAI_API_KEY is required when either the judge or the agent is enabled.
# Both features auto-detect on this variable (override with the matching
# --judge/--no-judge or --agent/--no-agent CLI flags).

# OPENAI_API_KEY=sk-...

# Optional: override the default judge model (gpt-4o-mini).
# CLI equivalent: --judge-model NAME.
# MCP_STRIKE_JUDGE_MODEL=gpt-4o-mini

# Optional: override the default agent model (gpt-4o-mini).
# CLI equivalent: --agent-model NAME.
# MCP_STRIKE_AGENT_MODEL=gpt-4o-mini
